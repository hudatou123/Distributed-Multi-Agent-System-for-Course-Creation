# Copy this file to .env and fill in your values. .env is gitignored.

# --- Gemini access ---
# Local default: Google AI Studio (Gemini Developer API). Get a free key at
# https://aistudio.google.com/apikey
GOOGLE_GENAI_USE_VERTEXAI="False"
GOOGLE_API_KEY=""

# --- Vertex AI path (used on GCP / Cloud Run instead of the API key) ---
# To use Vertex AI locally, set GOOGLE_GENAI_USE_VERTEXAI="True", leave
# GOOGLE_API_KEY empty, authenticate with `gcloud auth application-default login`,
# and set your project below.
GOOGLE_CLOUD_PROJECT=""
GOOGLE_CLOUD_LOCATION="global"

# --- Redis (orchestrator distributed course cache) ---
REDIS_URL="redis://localhost:6379"
